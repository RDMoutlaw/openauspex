{
  "name": "@openauspex/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Core library for OpenAuspex: event modelling, validation, Bitcoin freshness, OpenTimestamps, and evaluation.",
  "license": "MIT",
  "keywords": ["nostr", "warrant-canary", "bitcoin", "opentimestamps", "freshness"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openauspex/openauspex.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/openauspex/openauspex#readme",
  "bugs": "https://github.com/openauspex/openauspex/issues",
  "engines": { "node": ">=20" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "nostr-tools": "^2.7.0",
    "opentimestamps": "^0.4.9"
  }
}
