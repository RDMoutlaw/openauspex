{
  "name": "@openauspex/publisher",
  "version": "0.2.0",
  "type": "module",
  "description": "OpenAuspex operator side: compose, anchor, sign, publish, and timestamp canary attestations.",
  "license": "MIT",
  "keywords": [
    "nostr",
    "warrant-canary",
    "bitcoin",
    "opentimestamps"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RDMoutlaw/openauspex.git",
    "directory": "packages/publisher"
  },
  "homepage": "https://github.com/RDMoutlaw/openauspex#readme",
  "bugs": "https://github.com/RDMoutlaw/openauspex/issues",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
